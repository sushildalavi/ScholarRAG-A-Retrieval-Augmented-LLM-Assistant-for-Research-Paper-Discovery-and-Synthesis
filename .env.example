# Copy this file to `.env` and set real values only in `.env`.

# =========================
# Core models
# =========================
OPENAI_API_KEY=your-openai-key-here
RESEARCH_CHAT_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o-mini

# =========================
# Embeddings
# =========================
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages:
EMBEDDING_DOC_PREFIX=Represent this document for retrieval:
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SECONDS=45
EMBEDDING_RETRY_ATTEMPTS=3
EMBEDDING_RETRY_DELAY=0.75
EMBEDDING_VERSION=mxbai-embed-large-v1
EMBEDDING_MAX_QUERY_WORDS=128
EMBEDDING_MAX_DOC_WORDS=256
EMBEDDING_RAW_DIM=1024
VECTOR_STORE_DIM=1536

# Optional legacy OpenAI embedding fallback
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBED_TIMEOUT=20

# =========================
# Public provider API keys
# =========================
OPENALEX_API_KEY=
SPRINGER_API_KEY=
SPRINGER_OPEN_ACCESS_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
ELSEVIER_API_KEY=
IEEE_API_KEY=

# =========================
# Retrieval / public search
# =========================
PUBLIC_OPENALEX_LIMIT=15
PUBLIC_ARXIV_LIMIT=15
PUBLIC_CROSSREF_LIMIT=10
PUBLIC_S2_LIMIT=10
PUBLIC_SPRINGER_LIMIT=10
PUBLIC_ELSEVIER_LIMIT=10
PUBLIC_IEEE_LIMIT=10
ENABLE_WEB_FALLBACK=false
ARXIV_API_URL=https://export.arxiv.org/api/query
SPRINGER_META_VERSION=v2

# =========================
# Storage / runtime
# =========================
STORAGE_DIR=storage
EMBED_CACHE_ENABLED=1

# =========================
# Database / Supabase
# =========================
# Prefer DATABASE_URL in local and production. PG* vars are optional fallbacks.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=scholarrag
PGPASSWORD=scholarrag
PGDATABASE=scholarrag_db

# =========================
# Frontend / deployment
# =========================
BACKEND_BASE_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000
# If unset, Google auth is hidden and the app runs in guest mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =========================
# Landing page / latest research
# =========================
RESEARCH_FEED_CACHE_TTL_SECONDS=900
RESEARCH_FEED_TIMEOUT=12
